def task_1() -> None:
    # i–iii. создаём переменные с разными типами
    a = 10              # int
    b = 3.14            # float
    c = "Hello"         # str
    d = [1, 2, 3]       # list
    e = True            # bool

    # iv. выводим тип каждой переменной
    print(type(a))
    print(type(b))
    print(type(c))
    print(type(d))
    print(type(e))


# c. вызов функции
task_1()
